# MCP

FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    entr \
    && rm -rf /var/lib/apt/lists/*
    
RUN pip install --no-cache-dir \
    mcp[sse] \
    uvicorn \
    starlette \
    python-dotenv \
    neo4j

WORKDIR /app

EXPOSE 8001

CMD ["sh", "-c", "find . -name '*.py' | entr -r -n uvicorn mcp_server:starlette_app --host 0.0.0.0 --port 8001"]